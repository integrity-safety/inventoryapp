# Copy to .env for local dev (values here are safe local defaults).
# On Render, set these in the service's Environment tab instead.

SECRET_KEY=dev-insecure-change-me
DEBUG=True

# Comma-separated. Render injects RENDER_EXTERNAL_HOSTNAME automatically.
ALLOWED_HOSTS=localhost,127.0.0.1

# Leave blank locally to use SQLite. On Render, this is set from the database.
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# DB_SSL_REQUIRE=True

# The PWA's origin(s), comma-separated, for CORS. Blank + DEBUG allows all.
FRONTEND_ORIGINS=http://localhost:5173

# Allow field employees to self-assign assets (vs manager-only assignment).
ALLOW_SELF_ASSIGN=True
